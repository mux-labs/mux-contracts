# ============================================================
# Mux Protocol — Deployment Environment Variables
# Copy this file:  cp .env.deploy.example .env.deploy
# Fill in values, then:  source .env.deploy && npm run deploy
# Never commit .env.deploy — it is listed in .gitignore.
# ============================================================

# ------------------------------------------------------------
# Network
# ------------------------------------------------------------
SOROBAN_NETWORK=testnet           # testnet | localnet | mainnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org   # Horizon REST endpoint for the target network

# ------------------------------------------------------------
# Wallet / Keypair
# ------------------------------------------------------------
SOROBAN_ACCOUNT=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX  # Stellar public key of the deployer account
SOROBAN_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX       # Deployer secret key (keep private)

# ------------------------------------------------------------
# Friendbot (testnet / localnet only)
# ------------------------------------------------------------
FRIENDBOT_URL=https://friendbot.stellar.org   # Leave blank for mainnet; used by fund-accounts.sh

# ------------------------------------------------------------
# RPC / Node
# ------------------------------------------------------------
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org   # Soroban RPC endpoint for the target network

# ------------------------------------------------------------
# Program / Contract IDs (populated after first deploy; see config/addresses.json)
# ------------------------------------------------------------
MUX_ACCOUNT_CONTRACT_ID=           # mux-account program ID on the target network
MUX_BATCHER_CONTRACT_ID=           # mux-batcher program ID on the target network
MUX_PERMISSIONS_CONTRACT_ID=       # mux-permissions program ID on the target network
MUX_REGISTRY_CONTRACT_ID=          # mux-registry program ID on the target network
MUX_WALLET_REGISTRY_CONTRACT_ID=   # mux-wallet-registry program ID on the target network
