# Localnet Docker Compose Configuration
# Copy this to .env.localnet and customize as needed

# Soroban RPC endpoint configuration
SOROBAN_RPC_PORT=8000
LOCALNET_RPC_URL=http://localhost:8000

# Stellar network configuration
NETWORK=standalone

# Soroban network passphrase for the standalone network
# Use this when connecting from your application
LOCALNET_NETWORK_PASSPHRASE=Standalone Network ; February 2025

# Contract addresses on localnet
# These will be populated after deploying contracts to the local network
LOCALNET_MUX_ACCOUNT_ID=
LOCALNET_MUX_BATCHER_ID=
LOCALNET_MUX_PERMISSIONS_ID=

# When running tests, which network to use
SOROBAN_NETWORK=localnet

# Optional: Horizon API port (for Stellar CLI compatibility)
HORIZON_PORT=8001
